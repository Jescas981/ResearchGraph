# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (Cloud Run) — obligatorio en build; debe terminar en /api
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=https://cloudrunservicebackend.us-west1.run.app/api

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE CLOUD RUN (mismo proyecto que el backend; script scripts/deploy-cloud-run-frontend.sh)
# Copia estas líneas a frontend/.env
# ─────────────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=tu-proyecto-gcp
GCP_REGION=us-west1
CLOUD_RUN_FRONTEND_SERVICE=researchgraph-web
