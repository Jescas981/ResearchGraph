# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS — Supabase Postgres
# Supabase Dashboard → Settings → Database → Connection string
# Elige el pooler "Transaction" (puerto 6543) para Cloud Run / IPv4.
# Formato: postgresql://postgres.[ref]:[PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres
# (el código añade ?pgbouncer=true si falta, recomendado con node-pg).
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Máximo de conexiones en el pool (opcional, defecto 10).
# En Cloud Run con múltiples instancias, mantenlo bajo (ej. 5-10).
PG_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE STORAGE — PDFs
# Supabase Dashboard → Settings → API
#   · Project URL  → SUPABASE_URL
#   · service_role key (secret) → SUPABASE_SERVICE_ROLE_KEY  ⚠️ nunca expongas esto en el frontend
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PDF_BUCKET=pdfs

# ─────────────────────────────────────────────────────────────────────────────
# SERVIDOR
# Cloud Run inyecta PORT automáticamente (8080). No lo sobreescribas en producción.
# Para desarrollo local usa 3001.
# HOST se deja en 0.0.0.0 para que Cloud Run pueda recibir tráfico.
# ─────────────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE CLOUD RUN (mismas variables que scripts/deploy-cloud-run.sh)
# Copia estos valores a backend/.env para que el script los lea con `source`.
# ─────────────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=tu-proyecto-gcp
GCP_REGION=us-west1
CLOUD_RUN_SERVICE=researchgraph-api
